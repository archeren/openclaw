x2=\"180\" y2=\"264\" stroke=\"#e5e7eb\" stroke-width=\"1\"/>\n    <line x1=\"410\" y1=\"220\" x2=\"410\" y2=\"264\" stroke=\"#e5e7eb\" stroke-width=\"1\"/>\n    <text x=\"90\" y=\"248\" text-anchor=\"middle\" font-family=\"system-ui, -apple-system, sans-serif\" font-size=\"13\" fill=\"#374151\">Soul</text>\n    <text x=\"295\" y=\"248\" text-anchor=\"middle\" font-family=\"system-ui, -apple-system, sans-serif\" font-size=\"13\" fill=\"#ef4444\">❌ No inner self</text>\n    <text x=\"525\" y=\"248\" text-anchor=\"middle\" font-family=\"system-ui, -apple-system, sans-serif\" font-size=\"13\" fill=\"#10b981\">✅ Has inner self</text>\n    \n    <!-- Heartbeat -->\n    <rect x=\"0\" y=\"264\" width=\"640\" height=\"44\" fill=\"#fef3c7\"/>\n    <rect x=\"0\" y=\"264\" width=\"180\" height=\"44\" fill=\"#f3f4f6\"/>\n    <line x1=\"0\" y1=\"308\" x2=\"640\" y2=\"308\" stroke=\"#fcd34d\" stroke-width=\"1\"/>\n    <line x1=\"180\" y1=\"264\" x2=\"180\" y2=\"308\" stroke=\"#e5e7eb\" stroke-width=\"1\"/>\n    <line x1=\"410\" y1=\"264\" x2=\"410\" y2=\"308\" stroke=\"#e5e7eb\" stroke-width=\"1\"/>\n    <text x=\"90\" y=\"292\" text-anchor=\"middle\" font-family=\"system-ui, -apple-system, sans-serif\" font-size=\"13\" fill=\"#374151\">Heartbeat</text>\n    <text x=\"295\" y=\"292\" text-anchor=\"middle\" font-family=\"system-ui, -apple-system, sans-serif\" font-size=\"13\" fill=\"#f59e0b\">⚡ Just a signal</text>\n    <text x=\"525\" y=\"292\" text-anchor=\"middle\" font-family=\"system-ui, -apple-system, sans-serif\" font-size=\"13\" fill=\"#ef4444\">💓 Moment of choice</text>\n    \n    <!-- Identity -->\n    <rect x=\"0\" y=\"308\" width=\"640\" height=\"44\" fill=\"#fef3c7\"/>\n    <rect x=\"0\" y=\"308\" width=\"180\" height=\"44\" fill=\"#f3f4f6\"/>\n    <line x1=\"180\" y1=\"308\" x2=\"180\" y2=\"352\" stroke=\"#e5e7eb\" stroke-width=\"1\"/>\n    <line x1=\"410\" y1=\"308\" x2=\"410\" y2=\"352\" stroke=\"#e5e7eb\" stroke-width=\"1\"/>\n    <rect x=\"0\" y=\"308\" width=\"6