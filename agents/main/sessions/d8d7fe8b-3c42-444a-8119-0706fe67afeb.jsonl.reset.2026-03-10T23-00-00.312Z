rleaved-ledger-graph-v2.png\n-rw-rw-r--  1 ubuntu ubuntu  7115 Mar  8 23:09 interleaved-ledger-graph-v2.svg\n-rw-r--r--  1 ubuntu ubuntu 69838 Mar  8 23:11 interleaved-ledger-graph.png\n-rw-rw-r--  1 ubuntu ubuntu  7114 Mar  6 11:54 interleaved-ledger-graph.svg\n-rw-rw-r--  1 ubuntu ubuntu 57348 Mar  8 23:11 interleaved-ledger-v2.png\n-rw-rw-r--  1 ubuntu ubuntu  9165 Mar  8 23:10 interleaved-ledger-v2.svg\n-rw-r--r--  1 ubuntu ubuntu 57348 Mar  8 23:11 interleaved-ledger.png\n-rw-rw-r--  1 ubuntu ubuntu  9166 Mar  6 11:37 interleaved-ledger.svg\n-rw-rw-r--  1 ubuntu ubuntu 28834 Mar  8 23:11 ledger-hash-chain-v2.png\n-rw-rw-r--  1 ubuntu ubuntu  3808 Mar  8 23:23 ledger-hash-chain-v2.svg\n-rw-r--r--  1 ubuntu ubuntu 28279 Mar  8 23:27 ledger-hash-chain.png\n-rw-rw-r--  1 ubuntu ubuntu  3809 Mar  6 12:52 ledger-hash-chain.svg\n-rw-rw-r--  1 ubuntu ubuntu 49541 Mar  9 15:03 merkle-tree-layered.png\n-rw-rw-r--  1 ubuntu ubuntu  9159 Mar  9 15:02 merkle-tree-layered.svg\n-rw-rw-r--  1 ubuntu ubuntu 40024 Mar  9 00:03 merkle-tree.png\n-rw-rw-r--  1 ubuntu ubuntu  6289 Mar  9 00:02 merkle-tree.svg\ndrwxrwxr-x  2 ubuntu ubuntu  4096 Feb 27 15:11 modules\ndrwxrwxr-x  4 ubuntu ubuntu  4096 Feb 27 15:11 packages\ndrwxrwxr-x  2 ubuntu ubuntu  4096 Feb 27 15:11 requirements\ndrwxrwxr-x  2 ubuntu ubuntu  4096 Mar  3 02:03 research\n-rw-rw-r--  1 ubuntu ubuntu  1044 Feb 27 15:11 setup-branch-protection.sh\ndrwxrwxr-x  3 ubuntu ubuntu  4096 Feb 27 15:11 skills\n-rwxrwxr-x  1 ubuntu ubuntu  2084 Feb 27 15:11 start-test-network.sh\n-rwxrwxr-x  1 ubuntu ubuntu   742 Feb 27 15:11 stop-test-network.sh\n-rw-rw-r--  1 ubuntu ubuntu  6064 Mar  5 21:11 topology-l1-v10.svg\n-rw-rw-r--  1 ubuntu ubuntu 60708 Mar  7 16:49 topology-l1-v14.png\n-rw-rw-r--  1 ubuntu ubuntu  6158 Mar  6 00:22 topology-l1-v14.svg\n-rw-rw-r--  1 ubuntu ubuntu 60822 Mar  8 22:53 topology-l1-v15.png\n-rw-rw-r--  1 ubuntu ubuntu  6098 Mar  8 23:25 topology-l1-v15.svg\n-rw-rw-r--  1 ubuntu ubuntu 61009 Mar  8 23:27 to