ge) {\n+364     const conn = this.getConnection(peerUuid);\n+365     conn.send(message);  // Each connection is independent\n+366   }\n+367   \n+368   closeIdleConnections() {\n+369     // Close connections idle > 5 min\n+370     for (const [uuid, conn] of this.connections) {\n+371       if (conn.idleTime > 300000) {\n+372         conn.close();\n+373         this.connections.delete(uuid);\n+374       }\n+375     }\n+376   }\n+377 }\n+378 ```\n+379 \n+380 **Resource Considerations:**\n+381 \n+382 | Active P2P Connections | Memory Usage | Notes |\n+383 |------------------------|--------------|-------|\n+384 | 1 | ~1-5 MB | Minimal |\n+385 | 5 | ~5-25 MB | Normal for power users |\n+386 | 50+ | ~50-250 MB | Could be heavy, auto-close idle |\n+387 \n+388 **Optimization:** Auto-close P2P connections that are idle > 5 minutes to save resources.\n+389 \n 341 **Optimization Features:**\n 342 \n 343 | Feature | Purpose | Benefit |\n 344 |---------|---------|---------|\n     ...","firstChangedLine":335},"isError":false,"timestamp":1770532519367}}
