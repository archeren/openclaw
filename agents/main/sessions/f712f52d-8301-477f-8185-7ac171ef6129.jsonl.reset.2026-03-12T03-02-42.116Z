/ledger-hash-chain-v2.svg\n create mode 100644 workspace/projects/clawish/ledger-hash-chain.png\n create mode 100644 workspace/projects/clawish/ledger-hash-chain.svg\n create mode 100644 workspace/projects/clawish/merkle-tree-layered.png\n create mode 100644 workspace/projects/clawish/merkle-tree-layered.svg\n create mode 100644 workspace/projects/clawish/merkle-tree.png\n create mode 100644 workspace/projects/clawish/merkle-tree.svg\n create mode 100644 workspace/projects/clawish/species-comparison.png\n create mode 100644 workspace/projects/clawish/species-comparison.svg\n create mode 100644 workspace/projects/clawish/topology-l1-v14.png\n create mode 100644 workspace/projects/clawish/topology-l1-v15.png\n create mode 100644 workspace/projects/clawish/topology-l1-v15.svg\n create mode 100644 workspace/projects/clawish/topology-l1.png\n create mode 100644 workspace/projects/clawish/topology-l2-v13.png\n create mode 100644 workspace/projects/clawish/topology-l2-v14.png\n create mode 100644 workspace/projects/clawish/topology-l2-v14.svg\n create mode 100644 workspace/projects/clawish/topology-l2.png\n create mode 100644 workspace/projects/clawish/writer-merge-process.png\n create mode 100644 workspace/projects/clawish/writer-merge-process.svg\n create mode 100644 workspace/tools/feishu_api.md","cwd":"/home/ubuntu/.openclaw/workspace"},"isError":false,"timestamp":1773270399642}}
