sage) => message.content)).toEqual([\n      \"[summary] compacted older history\",\n      \"new assistant reply\",\n    ]);\n  });\n\n[342 more lines in file. Use offset=1500 to continue.]"}],"isError":false,"timestamp":1773544220403}}
