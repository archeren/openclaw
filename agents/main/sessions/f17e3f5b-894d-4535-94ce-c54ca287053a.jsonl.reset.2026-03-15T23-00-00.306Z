{"type":"message","id":"4da9f8d1","parentId":"da6e5985","timestamp":"2026-03-15T03:38:10.891Z","message":{"role":"toolResult","toolCallId":"call_e53aab5c75c248bb8abf9a3e","toolName":"exec","content":[{"type":"text","text":"1310:  async assemble(params: {\n1311-    sessionId: string;\n1312-    messages: AgentMessage[];\n1313-    tokenBudget?: number;\n1314-  }): Promise<AssembleResult> {\n1315-    try {\n1316-      this.ensureMigrated();\n1317-\n1318-      const conversation = await this.conversationStore.getConversationBySessionId(\n1319-        params.sessionId,\n1320-      );\n1321-      if (!conversation) {\n1322-        return {\n1323-          messages: params.messages,\n1324-          estimatedTokens: 0,\n1325-        };\n1326-      }\n1327-\n1328-      const contextItems = await this.summaryStore.getContextItems(conversation.conversationId);\n1329-      if (contextItems.length === 0) {\n1330-        return {\n1331-          messages: params.messages,\n1332-          estimatedTokens: 0,\n1333-        };\n1334-      }\n1335-\n1336-      // Guard against incomplete bootstrap/coverage: if the DB only has\n1337-      // raw context items and clearly trails the current live history, keep\n1338-      // the live path to avoid dropping prompt context.\n1339-      const hasSummaryItems = contextItems.some((item) => item.itemType === \"summary\");\n1340-      if (!hasSummaryItems && contextItems.length < params.messages.length) {"}],"details":{"status":"completed","exitCode":0,"durationMs":20,"aggregated":"1310:  async assemble(params: {\n1311-    sessionId: string;\n1312-    messages: AgentMessage[];\n1313-    tokenBudget?: number;\n1314-  }): Promise<AssembleResult> {\n1315-    try {\n1316-      this.ensureMigrated();\n1317-\n1318-      const conversation = await this.conversationStore.getConversationBySessionId(\n1319-        params.sessionId,\n1320-      );\n1321-      if (!conversation) {\n1322-        return {\n1323-          messages: params.messages,\n1324-    