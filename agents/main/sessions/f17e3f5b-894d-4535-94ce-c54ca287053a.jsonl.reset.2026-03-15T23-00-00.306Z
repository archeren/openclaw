messages.length > 0) {\n        return {\n          messages: params.messages,\n          estimatedTokens: 0,\n        };\n      }\n\n      const result: AssembleResultWithSystemPrompt = {\n\n[466 more lines in file. Use offset=1361 to continue.]"}],"isError":false,"timestamp":1773536123783}}
