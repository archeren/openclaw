compaction.ts:206:   * Counts message tokens outside the protected fresh tail and compares against\n/home/ubuntu/.openclaw/extensions/lossless-claw/src/compaction.ts:395:    // Phase 1: leaf passes over oldest raw chunks outside the protected tail.\n/home/ubuntu/.openclaw/extensions/lossless-claw/src/compaction.ts:578:   * Compute the ordinal boundary for protected fresh messages.\n/home/ubuntu/.openclaw/extensions/lossless-claw/src/compaction.ts:615:  /** Sum raw message tokens outside the protected fresh tail. */","cwd":"/home/ubuntu/.openclaw"},"isError":false,"timestamp":1773536662129}}
{"type":"message","id":"23eec91e","parentId":"43eb8f8e","timestamp":"2026-03-15T01:04:30.388Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I see \"protected fresh tail\" - this is the `freshTailCount` mechanism. But it's based on message count, not on marking specific messages as essential. Let me check if there's any concept of pinned or essential context items.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_cd3443405a1444b3af7b0819","name":"read","arguments":{"file_path":"/home/ubuntu/.openclaw/extensions/lossless-claw/src/compaction.ts","limit":60,"offset":575}}],"api":"openai-completions","provider":"qianfan","model":"glm-5","usage":{"input":110118,"output":115,"cacheRead":0,"cacheWrite":0,"totalTokens":110233,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773536662139}}
{"type":"message","id":"4458eca7","parentId":"23eec91e","timestamp":"2026-03-15T01:04:30.424Z","message":{"role":"toolResult","toolCallId":"call_cd3443405a1444b3af7b0819","toolName":"read","content":[{"type":"text","text":"  }\n\n  /**\n   * Compute the ordinal boundary for protected fresh messages.\n   *\n   * Messages with ordinal >= returned value are preserved as fresh tail.\n   */\n  private resolveFreshTailOrdinal(contextItems: ContextItemRecord[]): number {\n    const freshTailCount = this.resolveFreshTailCount();\n    if (freshTailCount <= 0) {\n      return Infinity;\n    }\n\n    const rawMessageItems = contextItems.filter(\n      (item) => item.itemType === \"message\" && item.messageId != null,\n    );\n    if (rawMessageItems.length === 0) {\n      return Infinity;\n    }\n\n    const tailStartIdx = Math.max(0, rawMessageItems.length - freshTailCount);\n    return rawMessageItems[tailStartIdx]?.ordinal ?? Infinity;\n  }\n\n  /** Resolve message token count with a content-length fallback. */\n  private async getMessageTokenCount(messageId: number): Promise<number> {\n    const message = await this.conversationStore.getMessageById(messageId);\n    if (!message) {\n      return 0;\n    }\n    if (\n      typeof message.tokenCount === \"number\" &&\n      Number.isFinite(message.tokenCount) &&\n      message.tokenCount > 0\n    ) {\n      return message.tokenCount;\n    }\n    return estimateTokens(message.content);\n  }\n\n  /** Sum raw message tokens outside the protected fresh tail. */\n  private async countRawTokensOutsideFreshTail(conversationId: number): Promise<number> {\n    const contextItems = await this.summaryStore.getContextItems(conversationId);\n    const freshTailOrdinal = this.resolveFreshTailOrdinal(contextItems);\n    let rawTokens = 0;\n\n    for (const item of contextItems) {\n      if (item.ordinal >= freshTailOrdinal) {\n        break;\n      }\n      if (item.itemType !== \"message\" || item.messageId == null) {\n        continue;\n      }\n      rawTokens += await this.getMessageTokenCount(item.messageId);\n    }\n\n    return rawTokens;\n  }\n\n  /**\n\n[699 more lines in file. Use offset=635 to continue.]"}],"isError":false,"timestamp":1773536670408}}
{"type":"message","id":"3086ce92","parentId":"4458eca7","timestamp":"2026-03-15T01:04:39.097Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"So `freshTailCount` only protects the **most recent N messages**. It doesn't have a concept of \"essential\" or \"pinned\" messages that should never be compacted regardless of position.\n\nLet me check the store to see if there's any metadata field that could be used for this.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_01024407d4ec4bae91275652","name":"exec","arguments":{"command":"grep -n \"pinned\\|essential\\|sticky\\|protected\\|priority\\|weight\" /home/ubuntu/.openclaw/extensions/lossless-claw/src/store/summary-store.ts 2>/dev/null | head -20","workdir":"/home/ubuntu/.openclaw"}}],"api":"openai-completions","provider":"qianfan","model":"glm-5","usage":{"input":110638,"output":162,"cacheRead":0,"cacheWrite":0,"totalTokens":110800,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773536670420}}
