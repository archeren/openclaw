onversationId, msgRecord.messageId);\n\n    return { ingested: true };\n  }\n\n  async ingest(params: {\n    sessionId: string;\n    message: AgentMessage;\n    isHeartbeat?: boolean;\n  }): Promise<IngestResult> {\n    this.ensureMigrated();\n    return this.withSessionQueue(params.sessionId, () => this.ingestSingle(params));\n  }\n\n  async ingestBatch(params: {\n    sessionId: string;\n    messages: AgentMessage[];\n    isHeartbeat?: boolean;\n  }): Promise<IngestBatchResult> {\n    this.ensureMigrated();\n    if (params.messages.length === 0) {\n      return { ingestedCount: 0 };\n    }\n    return this.withSessionQueue(params.sessionId, async () => {\n      let ingestedCount = 0;\n\n[619 more lines in file. Use offset=1208 to continue.]"}],"isError":false,"timestamp":1773541433055}}
