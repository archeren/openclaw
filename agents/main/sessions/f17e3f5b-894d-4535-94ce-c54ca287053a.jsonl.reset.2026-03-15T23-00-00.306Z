     content: \"<!-- preserve:soul -->\\n# SOUL.md\\n\\nIdentity content.\\n<!-- /preserve -->\",\n      }),\n    });\n\n    expect(result.ingested).toBe(false);\n  });\n\n  it(\"ingests content without preserve tags normally\", async () => {\n    const engine = createEngine();\n    const sessionId = \"no-preserve-tag-session\";\n\n    const result = await engine.ingest({\n      sessionId,\n      message: makeMessage({\n        role: \"user\",\n        content: \"This is a regular message without preserve tags.\",\n      }),\n    });\n\n    expect(result.ingested).toBe(true);\n\n    const conversation = await engine\n      .getConversationStore()\n      .getConversationBySessionId(sessionId);\n    expect(conversation).not.toBeNull();\n    expect(\n      await engine.getConversationStore().getMessageCount(conversation!.conversationId),\n    ).toBe(1);\n  });\n\n  it(\"afterTurn ingests auto-compaction summary and new turn messages\", async () => {","oldText":"  it(\"afterTurn ingests auto-compaction summary and new turn messages\", async () => {"}}],"api":"openai-completions","provider":"qianfan","model":"glm-5","usage":{"input":41864,"output":647,"cacheRead":0,"cacheWrite":0,"totalTokens":42511,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773542690663}}
