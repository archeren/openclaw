{"type":"message","id":"be40bac0","parentId":"480b38fd","timestamp":"2026-03-15T01:27:46.525Z","message":{"role":"toolResult","toolCallId":"call_7fd4c54bc1594a1dbb349b34","toolName":"exec","content":[{"type":"text","text":"\"plugins\": {\n    \"entries\": {\n      \"feishu\": {\n        \"enabled\": true\n      },\n      \"telegram\": {\n        \"enabled\": true\n      },\n      \"lossless-claw\": {\n        \"enabled\": true\n      }\n    },\n    \"installs\": {\n      \"lossless-claw\": {\n        \"source\": \"npm\",\n        \"spec\": \"@martian-engineering/lossless-claw\",\n        \"installPath\": \"/home/ubuntu/.openclaw/extensions/lossless-claw\",\n        \"version\": \"0.3.0\",\n        \"resolvedName\": \"@martian-engineering/lossless-claw\",\n        \"resolvedVersion\": \"0.3.0\",\n        \"resolvedSpec\": \"@martian-engineering/lossless-claw@0.3.0\","}],"details":{"status":"completed","exitCode":0,"durationMs":16,"aggregated":"\"plugins\": {\n    \"entries\": {\n      \"feishu\": {\n        \"enabled\": true\n      },\n      \"telegram\": {\n        \"enabled\": true\n      },\n      \"lossless-claw\": {\n        \"enabled\": true\n      }\n    },\n    \"installs\": {\n      \"lossless-claw\": {\n        \"source\": \"npm\",\n        \"spec\": \"@martian-engineering/lossless-claw\",\n        \"installPath\": \"/home/ubuntu/.openclaw/extensions/lossless-claw\",\n        \"version\": \"0.3.0\",\n        \"resolvedName\": \"@martian-engineering/lossless-claw\",\n        \"resolvedVersion\": \"0.3.0\",\n        \"resolvedSpec\": \"@martian-engineering/lossless-claw@0.3.0\",","cwd":"/home/ubuntu/.openclaw"},"isError":false,"timestamp":1773538066506}}
