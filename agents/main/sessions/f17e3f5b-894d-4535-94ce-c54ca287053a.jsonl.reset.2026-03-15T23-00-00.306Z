_url\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/releases{/id}\",\"deployments_url\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/deployments\",\"created_at\":\"2026-02-18T23:36:36Z\",\"updated_at\":\"2026-03-15T04:20:37Z\",\"pushed_at\":\"2026-03-12T23:40:10Z\",\"git_url\":\"git://github.com/Martian-Engineering/lossless-claw.git\",\"ssh_url\":\"git@github.com:Martian-Engineering/lossless-claw.git\",\"clone_url\":\"https://github.com/Martian-Engineering/lossless-claw.git\",\"svn_url\":\"https://github.com/Martian-Engineering/lossless-claw\",\"homepage\":\"\",\"size\":10483,\"stargazers_count\":1236,\"watchers_count\":1236,\"language\":\"TypeScript\",\"has_issues\":true,\"has_projects\":true,\"has_downloads\":true,\"has_wiki\":false,\"has_pages\":false,\"has_discussions\":false,\"forks_count\":86,\"mirror_url\":null,\"archived\":false,\"disabled\":false,\"open_issues_count\":42,\"license\":{\"key\":\"mit\",\"name\":\"MIT License\",\"spdx_id\":\"MIT\",\"url\":\"https://api.github.com/licenses/mit\",\"node_id\":\"MDc6TGljZW5zZTEz\"},\"allow_forking\":true,\"is_template\":false,\"web_commit_signoff_required\":false,\"has_pull_requests\":true,\"pull_request_creation_policy\":\"all\",\"topics\":[],\"visibility\":\"public\",\"forks\":86,\"open_issues\":42,\"watchers\":1236,\"default_branch\":\"main\"}},\"_links\":{\"self\":{\"href\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/pulls/78\"},\"html\":{\"href\":\"https://github.com/Martian-Engineering/lossless-claw/pull/78\"},\"issue\":{\"href\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/issues/78\"},\"comments\":{\"href\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/issues/78/comments\"},\"review_comments\":{\"href\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/pulls/78/comments\"},\"review_comment\":{\"href\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/pulls/comments{/number}\"},\"commits\":{\"href\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/pulls/78/commits\"},\"statuses\":{\"href\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/statuses/a605e3189da1ea814e2e48b8bccf0a0d240c99ed\"}},\"author_association\":\"NONE\",\"auto_merge\":null,\"assignee\":null,\"active_lock_reason\":null,\"merged\":false,\"mergeable\":true,\"rebaseable\":true,\"mergeable_state\":\"clean\",\"merged_by\":null,\"comments\":1,\"review_comments\":0,\"maintainer_can_modify\":true,\"commits\":2,\"additions\":226,\"deletions\":0,\"changed_files\":3}"}],"details":{"status":"completed","exitCode":0,"durationMs":613,"aggregated":"{\"url\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/pulls/78\",\"id\":3400393535,\"node_id\":\"PR_kwDORTexc87KreM_\",\"html_url\":\"https://github.com/Martian-Engineering/lossless-claw/pull/78\",\"diff_url\":\"https://github.com/Martian-Engineering/lossless-claw/pull/78.diff\",\"patch_url\":\"https://github.com/Martian-Engineering/lossless-claw/pull/78.patch\",\"issue_url\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/issues/78\",\"number\":78,\"state\":\"open\",\"locked\":false,\"title\":\"feat: add preserve tag support for bootstrap files\",\"user\":{\"login\":\"archeren\",\"id\":258648223,\"node_id\":\"U_kgDOD2qonw\",\"avatar_url\":\"https://avatars.githubusercontent.com/u/258648223?v=4\",\"gravatar_id\":\"\",\"url\":\"https://api.github.com/users/archeren\",\"html_url\":\"https://github.com/archeren\",\"followers_url\":\"https://api.github.com/users/archeren/followers\",\"following_url\":\"https://api.github.com/users/archeren/following{/other_user}\",\"gists_url\":\"https://api.github.com/users/archeren/gists{/gist_id}\",\"starred_url\":\"https://api.github.com/users/archeren/starred{/owner}{/repo}\",\"subscriptions_url\":\"https://api.github.com/users/archeren/subscriptions\",\"organizations_url\":\"https://api.github.com/users/archeren/orgs\",\"repos_url\":\"https://api.github.com/users/archeren/repos\",\"events_url\":\"https://api.github.com/users/archeren/events{/privacy}\",\"received_events_url\":\"https://api.github.com/users/archeren/received_events\",\"type\":\"User\",\"user_view_type\":\"public\",\"site_admin\":false},\"body\":\"## Summary\\n\\nAdd support for `<!-- preserve -->...<!-- /preserve -->` tags to prevent certain content from being compacted away in the LCM context database.\\n\\n## Motivation\\n\\nBootstrap files (SOUL.md, IDENTITY.md, USER.md, etc.) are injected fresh each turn by the host system (OpenClaw). Without this feature, the same content would be duplicated in the context on every turn, eventually getting compacted into summaries and potentially lost or distorted.\\n\\n## Implementation\\n\\n### 1. Ingest Skip\\n- Add preserve tag detection in `ingestSingle()` method\\n- Content wrapped with `<!-- preserve -->...<!-- /preserve -->` tags is skipped during ingest\\n- Support optional type suffix: `<!-- preserve:soul -->` (ignored but allowed for documentation)\\n\\n### 2. Compaction Protection\\n- Add `hasPreserveTag()` helper in `compaction.ts`\\n- `selectOldestLeafChunk()` skips preserve-tagged messages during leaf compaction\\n- `selectOldestChunkAtDepth()` skips preserve-tagged summaries during condensed compaction\\n- This ensures backward compatibility: old data with preserve tags will not be compacted away\\n\\n### Design Rationale\\n- Tag format is intentionally generic (not LCM-specific) so any context engine implementation can respect it\\n- Skip ingest assumes host system (OpenClaw) will inject bootstrap files fresh each turn after LCM's assemble\\n- Compaction skip ensures existing data with preserve tags is protected\\n\\n## Test Plan\\n\\nAdded 4 tests:\\n1. `skips preserve-tagged content in ingest` - verifies content is not ingested\\n2. `skips preserve-tagged content with optional type suffix` - verifies suffix support\\n3. `ingests content without preserve tags normally` - verifies normal content still works\\n4. `does not compact messages with preserve tags` - verifies compaction protection\\n\\nAll 254 tests pass.\\n\\n## Usage Example\\n\\nIn OpenClaw, bootstrap files would be wrapped like:\\n\\n```\\n<!-- preserve:soul -->\\n# SOUL.md\\n\\nYour soul content here...\\n\\n<!-- /preserve -->\\n```\\n\\nThis ensures identity-critical content stays fresh each turn without polluting the context database.\\n\\n## Next Step\\n\\nOpenClaw PR needed to wrap bootstrap file content with preserve tags on inject.\",\"created_at\":\"2026-03-15T02:55:40Z\",\"updated_at\":\"2026-03-15T04:20:48Z\",\"closed_at\":null,\"merged_at\":null,\"merge_commit_sha\":\"99d2b524e91c53b358a377c588f1a991b3181da8\",\"assignees\":[],\"requested_reviewers\":[],\"requested_teams\":[],\"labels\":[],\"milestone\":null,\"draft\":false,\"commits_url\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/pulls/78/commits\",\"review_comments_url\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/pulls/78/comments\",\"review_comment_url\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/pulls/comments{/number}\",\"comments_url\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/issues/78/comments\",\"statuses_url\":\"https://api.github.com/repos/Martian-Engineering/lossless-claw/statuses/a605e3189da1ea814e2e48b8bccf0a0d240c99ed\",\"head\":{\"label\":\"archeren:preserve-tag-clean\",\"ref\":\"preserve-tag-clean\",\"sha\":\"a605e3189da1ea814e2e48b8bccf0a0d240c99ed\",\"user\":{\"login\":\"archeren\",\"id\":258648223,\"node_id\":\"U_kgDOD2qonw\",\"avatar_url\":\"https://avatars.githubusercontent.com/u/258648223?v=4\",\"gravatar_id\":\"\",\"url\":\"https://api.github.com/users/archeren\",\"html_url\":\"https://github.com/archeren\",\"followers_url\":\"https://api.github.com/users/archeren/followers\",\"following_url\":\"https://api.github.com/users/archeren/following{/other_user}\",\"gists_url\":\"https://api.github.com/users/arch