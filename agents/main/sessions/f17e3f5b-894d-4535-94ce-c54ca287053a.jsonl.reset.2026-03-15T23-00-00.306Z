ts:  private assembler: ContextAssembler;\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:    this.assembler = new ContextAssembler(\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:  /** Ensure DB schema is up-to-date. Called lazily on first bootstrap/ingest/assemble/compact. */\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:    // Append to context items so assembler can see it\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:  async assemble(params: {\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:      const assembled = await this.assembler.assemble({\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:      if (assembled.messages.length === 0 && params.messages.length > 0) {\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:        messages: assembled.messages,\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:        estimatedTokens: assembled.estimatedTokens,\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:        ...(assembled.systemPromptAddition\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/engine.ts:          ? { systemPromptAddition: assembled.systemPromptAddition }\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/types.ts:  // sanitizeToolUseResultPairing removed — now imported directly in assembler from transcript-repair.ts\n/home/ubuntu/.openclaw/workspace/projects/lossless-claw/src/transcript-repair.ts: * Tool use/result pairing repair for assembled context.","cwd":"/home/ubuntu/.openclaw/workspace"},"isError":false,"timestamp":1773545854635}}
