{r.summary_id}: \\${r.preview.substring(0, 60)}...\\`);\n  });\n  console.log('');\n}\n\n// Check one summary in detail\nconst sum1 = db.prepare(\\`SELECT content FROM summaries WHERE summary_id = 'sum_8ed591ebb470a477'\\`).get();\nconsole.log('\\\\n--- Summary sum_8ed591ebb470a477 content (first 500 chars): ---');\nconsole.log(sum1.content.substring(0, 500));\n\""}}],"api":"openai-completions","provider":"qianfan","model":"glm-5","usage":{"input":59013,"output":596,"cacheRead":0,"cacheWrite":0,"totalTokens":59609,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773539842352}}
