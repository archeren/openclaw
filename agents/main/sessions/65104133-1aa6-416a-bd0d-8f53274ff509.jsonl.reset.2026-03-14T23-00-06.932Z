ssemble(params) {\n\t\treturn {\n\t\t\tmessages: params.messages,\n\t\t\testimatedTokens: 0\n\t\t};\n\t}\n\tasync afterTurn(_params) {}\n\tasync compact(params) {\n\t\tconst { compactEmbeddedPiSessionDirect } = await import(\"./compact.runtime-DMKUUCAZ.js\");\n\t\tconst runtimeContext = params.runtimeContext ?? {};\n\t\tconst currentTokenCount = params.currentTokenCount ?? (typeof runtimeContext.currentTokenCount === \"number\" && Number.isFinite(runtimeContext.currentTokenCount) && runtimeContext.currentTokenCount > 0 ? Math.floor(runtimeContext.currentTokenCount) : void 0);\n\t\tconst result = await compactEmbeddedPiSessionDirect({\n\t\t\t...runtimeContext,\n\t\t\tsessionId: params.sessionId,\n\t\t\tsessionFile: params.sessionFile,\n\t\t\ttokenBudget: params.tokenBudget,\n\t\t\t...currentTokenCount !== void 0 ? { currentTokenCount } : {},\n\t\t\tforce: params.force,\n\t\t\tcustomInstructions: params.customInstructions,\n\t\t\tworkspaceDir: runtimeContext.workspaceDir ?? process.cwd()\n\t\t});\n\t\treturn {\n\t\t\tok: result.ok,\n\t\t\tcompacted: result.compacted,\n\t\t\treason: result.reason,\n\t\t\tresult: result.result ? {\n\t\t\t\tsummary: result.result.summary,\n\t\t\t\tfirstKeptEntryId: result.result.firstKeptEntryId,\n\t\t\t\ttokensBefore: result.result.tokensBefore,\n\t\t\t\ttokensAfter: result.result.tokensAfter,\n\t\t\t\tdetails: result.result.details\n\t\t\t} : void 0\n\t\t};\n\t}\n\tasync dispose() {}\n};\nfunction registerLegacyContextEngine() {\n\tregisterContextEngine(\"legacy\", () => new LegacyContextEngine());","cwd":"/home/ubuntu/.openclaw/workspace"},"isError":false,"timestamp":1773461276748}}
{"type":"message","id":"3b1ff12a","parentId":"0dd27256","timestamp":"2026-03-14T04:08:37.731Z","message":{"role":"assistant","content":[{"type":"text","text":"Now I understand the Context Engine interface. Here's what it provides:\n\n---\n\n## Context Engine Interface\n\nThe Context Engine is a **plugin system** with these methods:\n\n| Method | Purpose | When Called |\n|--------|---------|-------------|\n| `bootstrap` | Initialize context for new session | Session start |\n| `ingest` | Process incoming messages | After each message |\n| `ingestBatch` | Process multiple messages | Batch operations |\n| `afterTurn` | Post-turn cleanup | After agent responds |\n| `assemble` | Build context for LLM | Before each LLM call |\n| `compact` | Compress/summarize context | When context too large |\n\n---\n\n## What Context Engine Can Do\n\nWith `sessionKey` now available, plugins can:\n\n1. **Exclude cron sessions from memory** — Don't store automated tasks in long-term memory\n2. **Stateless session flags** — Mark certain sessions as stateless\n3. **Scope storage by session type** — Different storage for DMs vs groups vs cron\n4. **Custom compaction logic** — Different summarization strategies per session type\n5. **Context filtering** — Include/exclude certain content based on session\n\n---\n\n## Example: lossless-claw Plugin\n\nThe PR mentions `lossless-claw` as an example plugin — it uses sessionKey to make routing decisions about memory storage.\n\n---\n\n## For clawish\n\nThis is useful for:\n- **Memory management** — Different memory scopes for different conversation types\n- **Context optimization** — Smarter compaction based on who we're talking to\n- **Session isolation** — Keep certain conversations out of long-term memory\n\nShould I explore how to write a Context Engine plugin for clawish-specific needs?"}],"api":"openai-completions","provider":"xunfei","model":"astron-code-latest","usage":{"input":53559,"output":358,"cacheRead":2816,"cacheWrite":0,"totalTokens":56733,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1773461276759}}
