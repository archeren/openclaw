e,\"url\":\"https://api.github.com/repos/archeren/lossless-claw\",\"forks_url\":\"https://api.github.com/repos/archeren/lossless-claw/forks\",\"keys_url\":\"https://api.github.com/repos/archeren/lossless-claw/keys{/key_id}\",\"collaborators_url\":\"https://api.github.com/repos/archeren/lossless-claw/collaborators{/collaborator}\",\"teams_url\":\"https://api.github.com/repos/archeren/lossless-claw/teams\",\"hooks_url\":\"https://api.github.com/repos/archeren/lossless-claw/hooks\",\"issue_events_url\":\"https://api.github.com/repos/archeren/lossless-claw/issues/events{/number}\",\"events_url\":\"https://api.github.com/repos/archeren/lossless-claw/events\",\"assignees_url\":\"https://api.github.com/repos/archeren/lossless-claw/assignees{/user}\",\"branches_url\":\"https://api.github.com/repos/archeren/lossless-claw/branches{/branch}\",\"tags_url\":\"https://api.github.com/repos/archeren/lossless-claw/tags\",\"blobs_url\":\"https://api.github.com/repos/archeren/lossless-claw/git/blobs{/sha}\",\"git_tags_url\":\"https://api.github.com/repos/archeren/lossless-claw/git/tags{/sha}\",\"git_refs_url\":\"https://api.github.com/repos/archeren/lossless-claw/git/refs{/sha}\",\"trees_url\":\"https://api.github.com/repos/archeren/lossless-claw/git/trees{/sha}\",\"statuses_url\":\"https://api.github.com/repos/archeren/lossless-claw/statuses/{sha}\",\"languages_url\":\"https://api.github.com/repos/archeren/lossless-claw/languages\",\"stargazers_url\":\"https://api.github.com/repos/archeren/lossless-claw/stargazers\",\"contributors_url\":\"https://api.github.com/repos/archeren/lossless-claw/contributors\",\"subscribers_url\":\"https://api.github.com/repos/archeren/lossless-claw/subscribers\",\"subscription_url\":\"https://api.github.com/repos/archeren/lossless-claw/subscription\",\"commits_url\":\"https://api.github.com/repos/archeren/lossless-claw/commits{/sha}\",\"git_commits_url\":\"https://api.github.com/repos/archeren/lossless-claw/git/commits{/sha}\",\"comments_url\":\"https://a