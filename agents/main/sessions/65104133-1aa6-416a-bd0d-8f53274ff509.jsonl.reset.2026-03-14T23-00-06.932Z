{"type":"message","id":"7132c4f0","parentId":"e313629e","timestamp":"2026-03-14T04:29:27.112Z","message":{"role":"toolResult","toolCallId":"call_52a71f4741804a51b6e7f2c7","toolName":"exec","content":[{"type":"text","text":"/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/agent-scope-BwZuo7sQ.js:const DEFAULT_MEMORY_ALT_FILENAME = \"memory.md\";\n/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/agent-scope-DBEC2O3x.js:const DEFAULT_MEMORY_ALT_FILENAME = \"memory.md\";\n/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/auth-profiles-iXW75sRj.js:\tconst compaction = defaults?.compaction;\n/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/auth-profiles-iXW75sRj.js:\t\tid: \"memorySearch->agents.defaults.memorySearch\",\n/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/auth-profiles-iXW75sRj.js:\t\tdescribe: \"Move top-level memorySearch to agents.defaults.memorySearch\",\n/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/auth-profiles-iXW75sRj.js:\t\t\tconst legacyMemorySearch = getRecord(raw.memorySearch);\n/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/auth-profiles-iXW75sRj.js:\t\t\t\tmovedMessage: \"Moved memorySearch → agents.defaults.memorySearch.\",\n/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/auth-profiles-iXW75sRj.js:\t\t\t\tmergedMessage: \"Merged memorySearch → agents.defaults.memorySearch (filled missing fields from legacy; kept explicit agents.defaults values).\"\n/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/auth-profiles-iXW75sRj.js:\t\tmessage: \"top-level memorySearch was moved; use agents.defaults.memorySearch instead (auto-migrated on load).\"\n/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/auth-profiles-iXW75sRj.js:\treturn readPrefs(prefsPath).tts?.summarize ?? DEFAULT_TTS_SUMMARIZE;"}],"details":{"status":"completed","exitCode":0,"durationMs":29,"aggregated":"/home/ubuntu/.npm-global/lib/node_modules/openclaw/dist/agent-scope-BwZuo7sQ.js:const DEFAULT_MEMORY_ALT_FILENAME