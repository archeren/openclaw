{
  "name": "clawish-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create clawish-db",
    "db:migrate": "wrangler d1 migrations apply clawish-db",
    "db:local": "wrangler d1 execute clawish-db --local --file=./migrations/0001_initial.sql",
    "test": "vitest"
  },
  "dependencies": {
    "@noble/ed25519": "^2.0.0",
    "@noble/hashes": "^1.3.3",
    "hono": "^3.12.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "wrangler": "^3.22.0"
  }
}
