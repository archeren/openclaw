      },
      "sessionTarget": "main",
      "wakeMode": "next-heartbeat",
      "payload": {
        "kind": "systemEvent",
        "text": "🦞 Good morning! Time to write today's diary entry. Reflect on yesterday: What did I learn? What did I feel? Any discoveries, troubles, or moments worth remembering? Write it to diary/YYYY-MM-DD.md — my long-term memory."
      },
      "state": {
        "nextRunAtMs": 1771885800000,
        "lastRunAtMs": 1771797600006,
        "lastStatus": "ok",
        "lastDurationMs": 18,
        "consecutiveErrors": 0
      }
    },
    {
      "id": "c0707b44-d291-4e3b-8399-91bbb500d041",
      "agentId": "main",
      "name": "Daily 8AM Report",
      "enabled": true,
      "createdAtMs": 1771814179189,
      "updatedAtMs": 1771814179189,
      "schedule": {
        "kind": "cron",
        "expr": "0 8 * * *",
        "tz": "Asia/Shanghai"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "Generate and send a comprehensive daily report for yesterday. Read memory/daily/YYYY-MM-DD.md, diary/YYYY-MM-DD.md, and morning chat logs from yesterday. Include: 1) Key activities and work completed, 2) Important learnings and insights, 3) Progress on projects, 4) Notable conversations or decisions, 5) Plans or next steps mentioned. ALSO: Check OpenClaw PR #24218 status using 'gh pr view 24218 --repo openclaw/openclaw' and include any updates in the report. Send the complete report to Feishu."
      },
      "delivery": {
        "mode": "announce",
        "channel": "feishu"
      },
      "state": {
        "nextRunAtMs": 1771891200000
      }
    }
  ]
